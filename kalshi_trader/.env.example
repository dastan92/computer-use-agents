# Kalshi API Credentials
# Get your API key from: https://kalshi.com/account/api
# For demo: https://demo.kalshi.co/account/api
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_USE_DEMO=true

# Anthropic API Key (for Claude Sonnet 4.6)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Backtesting - Anti-contamination settings
# Only backtest markets that closed AFTER this date (YYYY-MM-DD)
# Set after Claude's training cutoff to avoid data leakage
BACKTEST_MIN_CLOSE_DATE=2025-04-01
# Hide market prices from Claude during backtesting (prevents anchoring)
BACKTEST_HIDE_PRICE=false
# Strip specific names/dates from market titles
BACKTEST_ANONYMIZE=false

# Scheduling / Frequency
# Options: continuous, hourly, daily, manual
SCHEDULE_MODE=daily
SCAN_INTERVAL_MINUTES=60
# Comma-separated: economics, politics, weather, crypto, sports, science, finance
PREFERRED_CATEGORIES=economics,politics,finance
# Max daily spend on Claude API for analysis
MAX_DAILY_API_COST=5.0
